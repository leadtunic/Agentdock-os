    "doctor": "bash scripts/doctor.sh"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
