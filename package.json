{
  "name": "agentdock-os",
  "version": "0.1.0",
  "private": true,
  "description": "Open source self-hosted OS for governed AI agents: visual coding, browser automation, Git workflows, MCP hub, memory, skills, quality gates and audit logs.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
