# Application
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000

# Database
POSTGRES_USER=agentdock
POSTGRES_PASSWORD=agentdock
POSTGRES_DB=agentdock
DATABASE_URL=postgresql+psycopg://agentdock:agentdock@postgres:5432/agentdock

# Redis
REDIS_URL=redis://redis:6379/0

# Security
JWT_SECRET=change-me
ENCRYPTION_KEY=change-me-32-chars-minimum
SESSION_SECRET=change-me

# Storage
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=/data/storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1
S3_PUBLIC_URL=

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
LM_STUDIO_BASE_URL=http://host.docker.internal:1234

# Browser Runtime
BROWSER_RUNTIME_URL=http://browser-runtime:8010
BROWSER_HEADLESS=true
BROWSER_STORAGE_PATH=/data/browser

# Agent Runtime
AGENT_RUNTIME_URL=http://agent-runtime:8020
AGENT_MAX_RUNTIME_MINUTES=30
AGENT_DEFAULT_COST_LIMIT=2.00

# Gateway
GATEWAY_URL=http://gateway:8030
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# GitHub
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Observability
LOG_LEVEL=info
ENABLE_AUDIT_LOG=true
ENABLE_COST_TRACKING=true
